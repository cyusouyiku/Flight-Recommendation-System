<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.app.mapper.AirlineMapper">

    <resultMap id="BaseResultMap" type="com.example.app.entity.Airline">
        <id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="name" property="name"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT id, code, name
        FROM airline
        WHERE id = #{id}
    </select>

    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT id, code, name
        FROM airline
        WHERE code = #{code}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT id, code, name
        FROM airline
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO airline (code, name)
        VALUES (#{code}, #{name})
    </insert>

    <update id="update">
        UPDATE airline
        SET name = #{name}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM airline WHERE id = #{id}
    </delete>

    <delete id="deleteByCode">
        DELETE FROM airline WHERE code = #{code}
    </delete>
</mapper>
